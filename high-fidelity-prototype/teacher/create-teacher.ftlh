<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Schedule Sidekick - Create Teacher Account</title>
        <link rel="stylesheet" href="create-teacher.css" />
    </head>
    <body>
        <nav>
            <div class="logo">
                <h2>Schedule Sidekick</h2>
            </div>

            <ul>
                <li><a href="/high-fidelity-prototype/index.html">Home</a></li>
                <li><a href="#">About</a></li>
                <li><a href="#">Account</a></li>
            </ul>
        </nav>

        <header>
            <h1>Schedule Sidekick</h1>
            <p>Create Teacher Account</p>
        </header>

        <main>
            <div class="card">
                <h2>Teacher Information</h2>

                <form>
                    <label for="firstName">First Name</label>
                    <input type="text" id="firstName" value="John" />

                    <label for="lastName">Last Name</label>
                    <input type="text" id="lastName" value="Smith" />

                    <label for="email">School Email</label>
                    <input type="email" id="email" value="jsmith@uncg.edu" />

                    <label for="department">Department</label>
                    <select id="department">
                        <option selected>Computer Science</option>
                    </select>

                    <label for="bio">Short Bio</label>
                    <textarea id="bio" rows="5">
Professor of Computer Science specializing in software engineering and web development.</textarea
                    >

                    <div class="buttons">
                        <button class="cancel">
                            <a href="/high-fidelity-prototype/index.html"
                                >Cancel</a
                            >
                        </button>
                        <button class="create">
                            <a
                                href="/high-fidelity-prototype/teacher/teacher-dashboard.html"
                                >Create Account</a
                            >
                        </button>
                    </div>
                </form>

                <div class="login-link">
                    <p>
                        Already have an account?
                        <a href="teacher-login.html">Log In</a>
                    </p>
                </div>
            </div>
        </main>
    </body>
</html>
